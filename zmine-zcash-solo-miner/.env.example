# ─────────────────────────────────────────────────────────────────────────
# Zcash Solo Miner — local test environment
# Copy this to .env (in the same folder as docker-compose.yml) and edit.
#
# NEVER commit a real .env file to git.
# ─────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────
# Your Zcash mainnet transparent address (t1... or t3...).
# All block rewards are sent here.
# Leave blank to run in "sync only" mode (no mining reward configured).
MINER_ADDRESS=

# Redis authentication password — change to anything non-empty.
REDIS_PASSWORD=localtest_change_me_in_production

# ── WHERE DATA IS STORED ──────────────────────────────────────────────────
# Umbrel sets this automatically. For local testing the test script
# sets it to ./data relative to the project root.
# You can override it here if you want a custom path.
# APP_DATA_DIR=./data

# ── OPTIONAL TUNING ───────────────────────────────────────────────────────
# Stratum port — point ASICs/GPU miners here after sync.
STRATUM_PORT=3333

# CPU threads for the built-in Tromp solver (0 = disabled).
# Disable it during testing to save CPU — Zebra needs all available cores
# to sync quickly.
CPU_THREADS=0
